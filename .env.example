# Supabase — https://supabase.com/dashboard/project/lrwpkkqnbydaxmqbaice
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# New format (recommended): sb_publishable_...
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# New format (server only): sb_secret_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
# Legacy JWT keys (anon / service_role) also work if enabled in dashboard

# Optional: run `npm run db:migrate` from web/ (needs database password)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
GOOGLE_MAPS_SERVER_KEY=

# Paystack
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# NIMC
NIMC_API_KEY=sandbox
NIMC_BASE_URL=https://api.nimc.gov.ng/v1

# Clearance Webhooks
JALA_ADMIN_WEBHOOK_SECRET=

# Cron
CRON_SECRET=

# Expo (mobile)
EXPO_PUBLIC_API_URL=https://jala-ride-api.onrender.com
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_KEY=
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=
