# --- Option A: Render Postgres (auto-set when using render.yaml Blueprint) ---
# DATABASE_URL is injected automatically from the jala-ride-db database.

# --- Option B: Supabase Postgres (set manually in Render → Environment) ---
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# Auth
JWT_SECRET=change-me-in-production-use-long-random-string

# Server
PORT=4000
HOST=0.0.0.0
