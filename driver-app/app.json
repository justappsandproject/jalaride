{
  "expo": {
    "name": "Jala Ride Driver",
    "slug": "jala-ride-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jalaridedriver",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B6B3A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jalaride.driver",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Jala Ride Driver requires background location to dispatch trips to you.",
        "NSLocationWhenInUseUsageDescription": "Used for navigation and trip tracking.",
        "NSCameraUsageDescription": "Used to upload driver documents.",
        "NSPhotoLibraryUsageDescription": "Used to upload driver documents."
      }
    },
    "android": {
      "package": "com.jalaride.driver",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1B6B3A"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://jala-ride-api.onrender.com",
      "router": {},
      "eas": {
        "projectId": "96002418-6072-4db1-8608-c24503c49937"
      }
    },
    "owner": "justappsandp"
  }
}
