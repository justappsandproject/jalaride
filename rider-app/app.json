{
  "expo": {
    "name": "Jala Ride",
    "slug": "jala-ride-rider",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jalaride",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B6B3A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jalaride.rider",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Jala Ride uses your location to find nearby drivers and track your trip.",
        "NSCameraUsageDescription": "Used to upload your profile photo.",
        "NSPhotoLibraryUsageDescription": "Used to select your profile photo."
      }
    },
    "android": {
      "package": "com.jalaride.rider",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1B6B3A"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "11b32129-d861-48c5-992a-20cd71944616"
      }
    },
    "owner": "justappsandp"
  }
}
